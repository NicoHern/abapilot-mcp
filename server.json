{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "io.github.NicoHern/abapilot-mcp",
  "title": "ABAPilot",
  "description": "AI & MCP server for SAP ECC and on-premise S/4HANA — in-system ABAP, natural-language business queries and ABAP dev tooling. No BTP, no ADT, no RISE.",
  "version": "1.0.2",
  "repository": {
    "url": "https://github.com/NicoHern/abapilot-mcp",
    "source": "github"
  },
  "websiteUrl": "https://crimsonconsultingsl.com/abapilot/",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "abapilot",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ABAPILOT_URL",
          "description": "Full URL of the ABAPilot SICF endpoint",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "ABAPILOT_USER",
          "description": "SAP user for the connection",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "ABAPILOT_PASSWORD",
          "description": "SAP password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
